<robot name='yezibot'>

 <link name='base_link'>
   <visual>
   <origin xyz="0 0 0.0" rpy="0 0 0"/>
   <geometry>
     <cylinder radius="0.0" length="0.10"/>
   </geometry>
   </visual>
 </link>

  <link name='laser_link'>
    <visual>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
    <geometry>
        <cylinder radius="0.0" length="0.0"/>
    </geometry>
    <material name='black'>
       <color rgba="0.0 0.0 0.0 0.8 "/>
    </material>
    </visual>
  </link>

    <joint name="laser_joint" type="fixed">
        <parent link="base_link"/>
        <child link="laser_link"/>
        <origin xyz="0.0 0.0 0.75"/>
        
        
    </joint>
</robot>