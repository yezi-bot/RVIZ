<robot name='yezibot'>

 <link name='base_link'>
   <visual>
   <origin xyz="0 0 0.0" rpy="0 0 0"/>
   <geometry>
     <cylinder radius="0.2" length="0.10"/>
   </geometry>
   <material name='blue'>
      <color rgba="0.1 0.1 1.0 0.5 "/>
    </material>
   </visual>
 </link>

  <link name='laser_link'>
    <visual>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
    <geometry>
        <cylinder radius="0.05" length="0.0"/>
    </geometry>
    <material name=''>
       <color rgba="0.0 0.0 0.0 0.8 "/>
    </material>
    </visual>
  </link>

  <link name ='imu_link'>
   <visual>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
    <geometry>
        <box size="0.02 0.02 0.02"/>
    </geometry>
    </visual>
  </link>

    <joint name="laser_joint" type="fixed">
        <parent link="base_link"/>
        <child link="laser_link"/>
        <origin xyz="0.0 0.0 0.75"/>
        
        
    </joint>

    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <origin xyz="0.0 0.0 0.02"/>
    </joint>

</robot>